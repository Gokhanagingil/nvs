# Copy to /opt/nvs/.env on staging and restrict it to the deploy user.
# This file contains placeholders only. Never commit populated credentials.
NVS_LOG_LEVEL=info
NVS_AUTHENTICATION_TIMEOUT_MS=5000
NVS_ENABLE_NILES_MUTATIONS=false

# Compose host binding. Keep loopback-only behind an approved reverse proxy by default.
NVS_HOST_PORT=4100

# Docker network for internal NILES backend reachability. The compose interpolation
# default is bridge for deterministic config validation. Docker's predefined bridge
# network cannot be attached as a Compose external network, so CI proofs remap bridge
# to the user-defined nvs-ci-internal network. Real staging must override with
# grc-platform_grc-staging-network.
NVS_NILES_DOCKER_NETWORK=bridge

# Each credential is one JSON object with exactly "email" and "password".
# Use dedicated synthetic non-production identities only.
NVS_CREDENTIAL_NILES_DOT_STAGING_DOT_REQUESTER=
NVS_CREDENTIAL_NILES_DOT_STAGING_DOT_SERVICE_DASH_DESK_DASH_AGENT=
NVS_CREDENTIAL_NILES_DOT_STAGING_DOT_INCIDENT_DASH_MANAGER=
NVS_CREDENTIAL_NILES_DOT_STAGING_DOT_TENANT_DASH_ADMIN=
NVS_CREDENTIAL_NILES_DOT_STAGING_DOT_CROSS_DASH_TENANT_DASH_AGENT=
