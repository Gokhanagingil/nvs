{
  "name": "nvs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "install:locked": "corepack pnpm install --frozen-lockfile",
    "dev": "corepack pnpm --filter \"./apps/*\" --parallel run dev",
    "build": "corepack pnpm -r --if-present build",
    "test": "vitest run",
    "test:e2e": "playwright test --project=chromium",
    "lint": "eslint .",
    "format": "prettier --write \"apps/**/*.{ts,tsx,css,json,html}\" \"packages/**/*.{ts,tsx,json}\" \"scripts/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\" \".github/**/*.yml\" \"actors/**/*.yaml\" \"environments/**/*.yaml\" \"scenarios/**/*.yaml\" \"*.{ts,json,js,yaml,yml}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,css,json,html}\" \"packages/**/*.{ts,tsx,json}\" \"scripts/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\" \".github/**/*.yml\" \"actors/**/*.yaml\" \"environments/**/*.yaml\" \"scenarios/**/*.yaml\" \"*.{ts,json,js,yaml,yml}\"",
    "typecheck": "corepack pnpm -r --if-present typecheck && tsc --noEmit",
    "ci": "corepack pnpm format:check && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build && corepack pnpm test:e2e",
    "example:run": "tsx apps/api/src/cli.ts compile-run",
    "probe:niles": "tsx apps/api/src/cli.ts probe",
    "screenshots": "tsx scripts/capture-ui-screenshots.ts"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@nvs/adapter-niles": "workspace:*",
    "@nvs/contracts": "workspace:*",
    "@nvs/core": "workspace:*",
    "@nvs/domain": "workspace:*",
    "@nvs/secret-provider-environment": "workspace:*",
    "@nvs/storage-filesystem": "workspace:*",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "eslint": "9.39.5",
    "prettier": "3.9.5",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
